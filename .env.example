# ─── Cloudflare R2 Credentials ───
R2_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=your-bucket-name

# ─── Claude Code (optional) ───
# Set this if using API key auth instead of interactive login
ANTHROPIC_API_KEY=

# ─── Paths ───
# Local folder containing files to upload
UPLOAD_DIR=./uploads
# Local folder for ffmpeg converted output
OUTPUT_DIR=./output

# ─── Display (Linux GUI forwarding) ───
# Usually auto-detected, override if needed
# DISPLAY=:0
# QT_QPA_PLATFORM=xcb
